    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register a new store and owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Store-Id",
                "value": "{{storeId}}",
                "type": "text",
                "description": "Tenant store Id context filter"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"owner@myjewelstore.com\",\n  \"password\": \"secretpassword\",\n  \"storeName\": \"My Jewel Store\",\n  \"slug\": \"myjewelstore\",\n  \"businessType\": \"Jewellery\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Log in to an existing account",
          "request": {
            "method": "POST",
            "header": [
